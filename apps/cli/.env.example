# Copy to .env — never commit .env.
# Optional. When set, CLI talks to this Bulma API. Otherwise reads from
# ~/.config/bulma/credentials.json (apiUrl) or defaults to https://api.bul.ma.
BULMA_API_URL=http://localhost:8787

# Optional. When set, CLI uses this bearer token directly instead of the
# credentials file. Useful for CI / agent automation.
# BULMA_TOKEN=
