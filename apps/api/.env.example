# Copy to .env (gitignored). Never commit .env.
#
#   cp .env.example .env
#
# Two modes:
#  (A) Direct mode — fill the secrets below.
#  (B) Infisical mode — set INFISICAL_PROJECT_ID; `bun run dev` will pull
#      secrets from Infisical on every start. The literal secrets below
#      are unused in this mode (you can leave them blank or remove them).

# === Infisical (Option B) ===
# Your Infisical project id (from app.infisical.com/project/<this>/secrets).
# Not a secret. Each contributor can use their own Infisical project.
INFISICAL_PROJECT_ID=
INFISICAL_ENV=dev

# === Direct secrets (Option A) ===
BETTER_AUTH_SECRET=replace-me-32-bytes-base64

# Public origin where this API is served. Dev: http://localhost:8787. Prod: https://api.bul.ma
BETTER_AUTH_URL=http://localhost:8787

# Origin where apps/www is served (OAuth redirect + cookie scope).
# Dev: http://localhost:5173. Prod: https://bul.ma
WWW_URL=http://localhost:5173

# Google OAuth 2.0 client (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI must include:
#   http://localhost:8787/api/auth/callback/google     (dev)
#   https://api.bul.ma/api/auth/callback/google        (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth cloud telemetry / observability API key (https://better-auth.com).
# Optional — auth flows work without it.
BETTER_AUTH_API_KEY=

# === Cloudflare Tunnel (Phase 2 webhook intake) ===
# Required for BlindPay webhooks to reach your local dev API at https://local.bul.ma.
# Each contributor creates their own tunnel against their own zone:
#   cloudflared tunnel login                                   # picks zone
#   cloudflared tunnel create bulma-local-api                  # prints UUID
#   cloudflared tunnel route dns <UUID> <hostname>             # e.g. local.bul.ma
# Then paste the UUID below. The credentials file (~/.cloudflared/<UUID>.json) stays local.
CLOUDFLARED_TUNNEL_ID=
CLOUDFLARED_HOSTNAME=local.bul.ma
CLOUDFLARED_TARGET=http://localhost:8787

# === BlindPay (Phase 2+) ===
# https://app.blindpay.com — instance dashboard → API Keys.
BLINDPAY_API_KEY=
BLINDPAY_INSTANCE_ID=
BLINDPAY_API_URL=https://api.blindpay.com/v1
# Network + token for development instance.
# Production: polygon + USDC. Development: polygon_sepolia + USDB.
BLINDPAY_NETWORK=polygon_sepolia
BLINDPAY_TOKEN=USDB
# Hosted KYC invite mount URL — receiver onboarding link is built as
#   {BLINDPAY_HOSTED_INVITE_URL}?instanceId={instance}&type={type}&kyc_type={kyc}&token={jwt}
BLINDPAY_HOSTED_INVITE_URL=https://app.blindpay.com/e/receivers/invite
# Webhook signing secret. BlindPay dashboard → instance → Webhooks → Get secret.
# Format: whsec_<base64>
BLINDPAY_WEBHOOK_SECRET=
# Partner-fee configs. Quote uses FREE when the user has an available referral
# credit (consumed at execute), PAID otherwise.
BLINDPAY_PARTNER_FEE_ID_FREE=
BLINDPAY_PARTNER_FEE_ID_PAID=
