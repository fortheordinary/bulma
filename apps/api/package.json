{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "tunnel": "bun run scripts/tunnel.ts",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "bun test",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c ../../packages/oxc/.oxlintrc.json src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply bulma --local",
    "db:migrate:remote": "wrangler d1 migrations apply bulma --remote",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .wrangler .turbo"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.3",
    "@scalar/hono-api-reference": "^0.10.19",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "loglayer": "^8.5.0",
    "nanoid": "^5.1.11",
    "serialize-error": "^11.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@bulma/oxc-config": "workspace:*",
    "@bulma/typescript-config": "workspace:*",
    "@cloudflare/workers-types": "^4.20241224.0",
    "drizzle-kit": "^0.30.1",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.6",
    "typescript": "^5.7.2",
    "wrangler": "^4.95.0"
  }
}
