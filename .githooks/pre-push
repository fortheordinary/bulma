#!/bin/sh
# Block pushing any commit whose author OR committer email is not agent@bul.ma.
# Reads ref updates on stdin: <local ref> <local sha> <remote ref> <remote sha>.
required="agent@bul.ma"
zero="0000000000000000000000000000000000000000"
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue            # branch delete — nothing to check
  if [ "$remote_sha" = "$zero" ]; then
    commits=$(git rev-list "$local_sha" --not --remotes)   # new branch: only its new commits
  else
    commits=$(git rev-list "$remote_sha..$local_sha")
  fi
  for c in $commits; do
    ae=$(git log -1 --format='%ae' "$c")
    ce=$(git log -1 --format='%ce' "$c")
    if [ "$ae" != "$required" ] || [ "$ce" != "$required" ]; then
      echo "✖ push blocked: $c author/committer ($ae / $ce) != $required" >&2
      status=1
    fi
  done
done

[ "$status" -ne 0 ] && echo "  rewrite offending commits with agent@bul.ma before pushing." >&2
exit $status
